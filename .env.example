# ============================================================
# VisionLife · Variables de la Conversions API (Meta CAPI)
# ------------------------------------------------------------
# Copia este archivo a ".env" SOLO en local, o (mejor) define
# estas variables en Dokploy → tu servicio → Environment.
# NUNCA subas el token real al repositorio.
# ============================================================

# Activa el reenvío de eventos de servidor.
CAPI_ENABLED=false

# Token de la Conversions API (Events Manager → Configuración →
# Conversions API → Generar token de acceso). SECRETO.
CAPI_ACCESS_TOKEN=

# Mismo Pixel ID que usas en el navegador.
CAPI_PIXEL_ID=

# (Opcional) Código de "Probar eventos" para verlos en tiempo real.
CAPI_TEST_EVENT_CODE=

# (Opcional) Restringe el origen permitido, p. ej. https://visionlife.tudominio.com
CAPI_ALLOWED_ORIGIN=

# (Opcional) Versión de la Graph API.
CAPI_API_VERSION=v21.0
